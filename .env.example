SUBLB_GROK_IMAGE_MODEL=grok-imagine-1.0
SUBLB_GROK_IMAGE_API_KEY=your_grok_image_api_key_here

# 旧图文分组仅保留占位，不在公开文档里当作稳定生图入口说明
