{
  "/v1/videos": {
    "post": {
      "tags": [
        "Videos"
      ],
      "summary": "Create Video",
      "description": "Videos create endpoint.\nSupports JSON and multipart/form-data using only reverse-supported params.",
      "operationId": "create_video_v1_videos_post",
      "requestBody": {
        "content": {
          "application/json": {
            "schema": {
              "properties": {
                "prompt": {
                  "type": "string",
                  "title": "Prompt",
                  "description": "Video prompt"
                },
                "model": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "title": "Model",
                  "description": "Model id",
                  "default": "grok-imagine-1.0-video"
                },
                "size": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "title": "Size",
                  "description": "Output size",
                  "default": "1792x1024"
                },
                "seconds": {
                  "anyOf": [
                    {
                      "type": "integer"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "title": "Seconds",
                  "description": "Video length in seconds",
                  "default": 6
                },
                "quality": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "title": "Quality",
                  "description": "Quality: standard/high",
                  "default": "standard"
                },
                "image_reference": {
                  "anyOf": [
                    {},
                    {
                      "type": "null"
                    }
                  ],
                  "title": "Image Reference",
                  "description": "Structured image reference"
                },
                "input_reference": {
                  "anyOf": [
                    {},
                    {
                      "type": "null"
                    }
                  ],
                  "title": "Input Reference",
                  "description": "Multipart input reference file"
                }
              },
              "type": "object",
              "required": [
                "prompt"
              ],
              "title": "VideoCreateRequest",
              "description": "Supported create params only; unknown fields are ignored by design."
            }
          },
          "multipart/form-data": {
            "schema": {
              "properties": {
                "prompt": {
                  "type": "string"
                },
                "model": {
                  "type": "string",
                  "default": "grok-imagine-1.0-video"
                },
                "size": {
                  "type": "string",
                  "default": "1792x1024"
                },
                "seconds": {
                  "type": "integer",
                  "default": 6
                },
                "quality": {
                  "type": "string",
                  "default": "standard"
                },
                "image_reference": {
                  "type": "string",
                  "description": "JSON string for image_reference object"
                },
                "input_reference": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "type": "object",
              "required": [
                "prompt"
              ]
            }
          }
        },
        "required": true
      },
      "responses": {
        "200": {
          "description": "Successful Response",
          "content": {
            "application/json": {
              "schema": {}
            }
          }
        }
      },
      "security": [
        {
          "API Key": []
        }
      ]
    }
  },
